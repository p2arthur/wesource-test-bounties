generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Top level: The Project
model Project {
  id           Int          @id @default(autoincrement())
  name         String
  description  String?
  category     String
  creator      String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  repositories Repository[]
}

// 2. The Repository: Linked to a Project
model Repository {
  id        Int      @id @default(autoincrement())
  githubUrl String   @unique // e.g., https://github.com/algorandfoundation/algokit-utils-ts
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bounties  Bounty[] // One repo can have many issue bounties
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. The Bounty: This is your "Issue" tracking
model Bounty {
  id          Int          @id @default(autoincrement()) // Starts at 1, unique ID
  issueNumber Int // e.g., 424
  issueUrl    String       @unique // e.g., https://github.com/org/repo/issues/424
  bountyKey   String       @unique @map("bounty_key")
  amount      Float
  status      BountyStatus @default(OPEN)

  // Relations
  repositoryId Int
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  // User Relations
  creatorWallet String
  winnerId      Int?
  winner        User?  @relation(fields: [winnerId], references: [id])

  // Metadata
  githubIssueId BigInt    @map("github_issue_id") // The internal GitHub global ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  claimedAt     DateTime?
  claimerPR     String?   @map("claimer_pull_request")

  // Oracle tracking fields
  processedEventId BigInt?   @map("processed_event_id") // GitHub event ID to prevent double processing
  lastCheckedAt    DateTime? @map("last_checked_at") // For If-Modified-Since header
  stateReason      String?   @map("state_reason") // completed, not_planned, etc.
  closedByCommitId String?   @map("closed_by_commit_id") // Commit SHA that closed the issue

  @@index([issueNumber])
  @@index([status])
}

model User {
  id          Int      @id @default(autoincrement())
  githubId    Int      @unique
  username    String?
  wallet      String?
  wonBounties Bounty[] // Relation back to bounties won by this user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum BountyStatus {
  OPEN
  READY_FOR_CLAIM
  CLAIMED
  CANCELLED // Issue closed as not_planned
  REFUNDABLE // Issue cancelled, funds can be refunded
}
